rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Agent Logs: Publicly readable and writable for testing
    match /agent_logs/{docId} {
      allow read, write: if true;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128;
    }

    // Market data: Publicly readable, system-only write (simulated via auth for now)
    match /market/{itemId}/orders/{orderId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /market_data/{docId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /arbitrage_opportunities/{docId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // Handshake verification
    match /test/{docId} {
      allow read: if true;
    }

    // Executions: Logged by user
    match /executions/{executionId} {
      allow read, write: if isSignedIn();
    }

    // Settings: Private per user
    match /settings/{userId} {
      allow read, write: if isOwner(userId);
    }

    // User-specific data (orders, strategies, config, etc.)
    match /users/{userId} {
      allow read, write: if isOwner(userId);
      match /{allPaths=**} {
        allow read, write: if isOwner(userId);
      }
    }

    // Executions: Logged by user
    match /executions/{executionId} {
      allow read, write: if isSignedIn();
    }
  }
}

# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Github Auto-Push
GITHUB_TOKEN=""
GITHUB_REPO="username/repo"


# Server-Side Headless Auth (Highly Stable, NO UI DROPS)
# Do NOT expose these to the browser!
WALLET_SEED_PHRASE=""
TELEGRAM_SESSION_STRING=""
TELEGRAM_USER_SESSION=""
MTPROTO_USER_SESSION_STRING=""
MTPROTO_STRING_SESSION=""

# Portals API Authorization Token (e.g., "tma query_id=...")
PORTALS_AUTH=""

# Fragment API Authorization Token (e.g., "tma query_id=...")
FRAGMENT_AUTH=""
PORTALS_AUTH=""

# Telegram MTProto API (my.telegram.org)
VITE_TELEGRAM_API_ID=""
VITE_TELEGRAM_API_HASH=""

# Telegram Companion Bot Token (Optional)
# Токен от @BotFather для автоматического получения кода входа
VITE_TELEGRAM_BOT_TOKEN=""

# TON Integration
VITE_TON_API_KEY=""
VITE_TONCONSOLE_API_KEY=""
VITE_TONCENTER_API_KEY=""
VITE_MAIN_WALLET_ADDRESS="UQAufjpnlVShZlGx5E9rPk7q6but9WvLWvit3ANIUn883v9V"
VITE_BUM_WALLET_ADDRESS="UQB16zDilSdn9K9BXtdeqo_q_MO2_SYftcZyA9GA8LuI52Zj"

